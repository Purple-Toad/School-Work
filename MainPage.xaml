<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="In_Class_Assignment_5.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">


            <Button
                x:Name="CircleBtn"
                Text="Add Circle" 
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill" />
            <Button 
                x:Name="RectangleBtn"
                Text="Add Rectangle"
                Clicked="RectangleBtn_Clicked"/>
            <Label x:Name="ShapeListLabel"></Label>
            <Button 
                x:Name="ClearBtn"
                Text="Clear"
                Clicked="ClearBtn_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
